# Copy this file to `.env` for local development. Do NOT commit `.env`.
# In production, set these same variables in the Render dashboard.

# Session signing key. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Advisor accounts as JSON: {"email": "bcrypt-hash", ...}
# Generate each hash with:  python make_hash.py
# Keep the whole thing on ONE line.
ADVISOR_ACCOUNTS={"advisor@example.com": "$2b$12$REPLACE_WITH_REAL_HASH"}

# Local dev only: browsers won't send a secure cookie over http://localhost,
# so set this to false locally. Leave it TRUE (or unset) in production.
COOKIE_HTTPS_ONLY=false

# Optional: session lifetime in seconds (default 43200 = 12 hours)
# SESSION_MAX_AGE=43200
