# Copy this file to `.env` for local development. Do NOT commit `.env`.
# In production, set these same variables in the Render dashboard.

# --- Core -------------------------------------------------------------------
# Session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Local dev only: browsers won't send a secure cookie over http://localhost,
# so set this to false locally. Leave it TRUE (or unset) in production.
COOKIE_HTTPS_ONLY=false

# --- Airtable allowlist -----------------------------------------------------
# Active advisors in this table are allowed to log in.
AIRTABLE_TOKEN=your-airtable-token
# Defaults below match the BillionToOne Medical Advisor base; override if needed.
# AIRTABLE_BASE_ID=appHoBhZB7dghdDBT
# AIRTABLE_TABLE=Advisors Roster 🩺
# AIRTABLE_EMAIL_FIELD=Email
# AIRTABLE_STATUS_FIELD=Status
# ALLOWED_STATUS=Active

# --- Email (SendGrid HTTPS API) ---------------------------------------------
# Render blocks outbound SMTP, so login codes are sent via SendGrid's API.
# If SENDGRID_API_KEY is unset, codes are printed to the server log instead
# (handy for local testing). MAIL_FROM must be a SendGrid-verified sender.
SENDGRID_API_KEY=SG.your-sendgrid-api-key
MAIL_FROM=your-verified-sender@billiontoone.com
MAIL_FROM_NAME=BillionToOne Medical Advisors

# --- Optional tuning --------------------------------------------------------
# CODE_TTL_SECONDS=600      # login code lifetime (default 10 min)
# MAX_ATTEMPTS=5            # wrong-code attempts before a code is voided
# RESEND_COOLDOWN=60        # seconds between code sends per email
# ROSTER_CACHE_TTL=300      # seconds to cache the Airtable allowlist
# SESSION_MAX_AGE=43200     # signed-in session lifetime (default 12h)

# --- Local testing without Airtable/SMTP ------------------------------------
# Comma-separated emails treated as allowed WITHOUT querying Airtable.
# Use for local testing only; leave unset in production.
# DEV_ALLOWED_EMAILS=you@billiontoone.com
